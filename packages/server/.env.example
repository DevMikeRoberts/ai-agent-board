# Server port (default: 3001)
PORT=3001

# Comma-separated list of allowed CORS origins.
# The Tailscale IP (100.x.x.x) is included for remote dev access over Tailscale VPN.
# Update or remove as needed for your network.
ALLOWED_ORIGINS=http://localhost:4175,http://localhost:4176

# SQLite database path (default: ./data/kanban.db relative to cwd)
DB_PATH=./data/kanban.db
